---
import ThemeToggle from './ThemeToggle.astro';

const navLinks = [
  { href: '/', label: '首页' },
  { href: '/bases', label: '阵型库' },
  { href: '/about', label: '关于' },
  { href: '/contact', label: '联系我' },
  { href: 'https://clashpost.com/apk', label: '下载', external: true },
];

const currentPath = Astro.url.pathname;
---

<header class="fixed top-0 left-0 right-0 z-50" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px); border-bottom: 1px solid var(--border-light);">
  <nav class="container mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="flex items-center">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--accent);">
        <path d="M14.5 17.5L3 6V3h3l11.5 11.5"/>
        <path d="M13 19l6-6"/>
        <path d="M16 16l4 4"/>
      </svg>
    </a>

    <div class="flex items-center gap-0.5 md:gap-1 overflow-x-auto">
      {navLinks.map((link) => (
        <a
          href={link.href}
          target={link.external ? '_blank' : undefined}
          rel={link.external ? 'noopener' : undefined}
          class:list={[
            'px-2 md:px-3 py-1.5 rounded-lg text-xs md:text-sm font-medium transition-colors duration-150 whitespace-nowrap flex-shrink-0',
            currentPath === link.href
              ? 'text-[var(--accent)] bg-[var(--accent-soft)]'
              : 'text-[var(--text-secondary)] hover:text-[var(--text)]',
          ]}
        >
          {link.label}
        </a>
      ))}
      <div class="ml-1 md:ml-2 pl-1 md:pl-2 flex-shrink-0" style="border-left: 1px solid var(--border-light);">
        <ThemeToggle />
      </div>
    </div>
  </nav>
</header>
